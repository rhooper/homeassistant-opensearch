{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Lint",
            "type": "shell",
            "command": "/bin/bash ./scripts/lint"
        },
        {
            "label": "Run all Tests",
            "type": "shell",
            "command": "/bin/bash ./scripts/test"
        },
        {
            "label": "Update Test Snapshots for current file",
            "type": "shell",
            "command": "/bin/bash ${workspaceFolder}/scripts/update_snapshots ${file}",
            "problemMatcher": []
        },
        {
            "label": "Update Test Snapshots",
            "type": "shell",
            "command": "/bin/bash ./scripts/update_snapshots"
        },
        {
            "label": "Generate coverage report",
            "type": "shell",
            "command": "/bin/bash ./scripts/coverage"
        },
        {
            "label": "Run OpenSearch 3.5.0 on fuzzybee.local (HTTP Port 9200)",
            "type": "shell",
            "command": "/bin/bash ./scripts/run_opensearch 3.5.0"
        },
        {
            "label": "Clean up OpenSearch containers on fuzzybee.local",
            "type": "shell",
            "command": "/bin/bash ./scripts/clean_opensearch"
        },
    ]
}
